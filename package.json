  },
  "devDependencies": {
    "@fleet-sdk/compiler": "^0.12.0",
    "@fleet-sdk/mock-chain": "^0.12.0",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsdown": "^0.22.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
